{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "MergeWatch",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg",
    "href": "https://mergewatch.ai"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#00ff88",
    "light": "#00ff88",
    "dark": "#00cc66"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/mergewatch/mergewatch"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://mergewatch.ai"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "overview/introduction",
              "overview/how-it-works",
              "overview/quickstart"
            ]
          },
          {
            "group": "Self-Hosting",
            "pages": [
              "self-hosting/prerequisites",
              "self-hosting/install",
              "self-hosting/manual-install",
              "self-hosting/byoc",
              "self-hosting/upgrading",
              "self-hosting/uninstalling"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/mergewatch-yml",
              "configuration/review-behavior",
              "configuration/skip-rules",
              "configuration/custom-instructions"
            ]
          },
          {
            "group": "GitHub App",
            "pages": [
              "github-app/permissions",
              "github-app/org-install",
              "github-app/personal-install",
              "github-app/webhook-events"
            ]
          },
          {
            "group": "Deployment",
            "pages": [
              "deployment/architecture",
              "deployment/deployment-models",
              "deployment/bedrock-regions",
              "deployment/sam-template"
            ]
          },
          {
            "group": "Dashboard",
            "pages": [
              "dashboard/overview",
              "dashboard/reviews",
              "dashboard/repositories",
              "dashboard/settings",
              "dashboard/profile"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/cli",
              "reference/env-vars",
              "reference/changelog",
              "reference/faq",
              "reference/troubleshooting"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/mergewatch/mergewatch",
          "icon": "github"
        },
        {
          "anchor": "Changelog",
          "href": "https://docs.mergewatch.ai/reference/changelog",
          "icon": "list"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/mergewatch/mergewatch"
    }
  }
}
